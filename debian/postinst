#!/bin/sh
set -e

case "$1" in
    configure)
        mkdir -p /etc/octave/pkg-init.d
        cat > /etc/octave/pkg-init.d/quadriga-lib.m <<'EOF'
% Auto-generated by quadriga-lib package — do not edit manually
% Adds the quadriga-lib MEX directory to Octave's path at startup
addpath('/usr/share/quadriga-lib');
EOF
        ;;
esac

#DEBHELPER#
exit 0
