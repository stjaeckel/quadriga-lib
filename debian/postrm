#!/bin/sh
set -e

case "$1" in
    remove|purge)
        if [ -f /usr/share/octave/site/m/startup/octaverc ]; then
            sed -i '/Auto-generated by quadriga-lib/d' /usr/share/octave/site/m/startup/octaverc
            sed -i "/addpath('\/usr\/share\/quadriga-lib')/d" /usr/share/octave/site/m/startup/octaverc
            # Remove file if it is now empty or only whitespace
            if ! grep -q '[^[:space:]]' /usr/share/octave/site/m/startup/octaverc; then
                rm -f /usr/share/octave/site/m/startup/octaverc
            fi
        fi
        ;;
esac

#DEBHELPER#
exit 0